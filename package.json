{
  "name": "travel-ledger",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run api\" \"vite --port 5173\"",
    "api": "json-server --watch db.json --port 3001",
    "start": "json-server --watch db.json --port $PORT --host 0.0.0.0",
    "build": "vue-tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "json-server": "^0.17.4",
    "lucide-vue-next": "^0.408.0",
    "pinia": "^2.1.7",
    "vue": "^3.4.31",
    "vue-router": "^4.3.3"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "@vitejs/plugin-vue": "^5.0.5",
    "concurrently": "^8.2.2",
    "typescript": "^5.5.3",
    "vite": "^5.3.3",
    "vue-tsc": "^2.0.26"
  }
}